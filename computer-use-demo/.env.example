# API Key for the AI Agent
ANTHROPIC_API_KEY=your_api_key_here

# Use the official Anthropic API endpoint (default when not specified)
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# Model to use (Claude Haiku 4.5 for faster responses, or use claude-sonnet-4-5-20250929)
ANTHROPIC_MODEL=your_model_here

# (Optional) Display Configuration
WIDTH=1024
HEIGHT=768
