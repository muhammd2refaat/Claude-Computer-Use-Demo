# ============================================
# Computer Use Agent - Environment Configuration
# ============================================

# LLM API Keys (choose one)
# -------------------------
# Option 1: Anthropic Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Option 2: Google Gemini API (use this as alternative)
# Keys starting with "AIza" will automatically route to Gemini
GEMINI_API_KEY=your_gemini_api_key_here

# (Optional) Custom Anthropic Base URL
# ANTHROPIC_BASE_URL=https://your-custom-endpoint.com

# (Optional) Model Configuration
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Display Configuration
# -------------------------
WIDTH=1024
HEIGHT=768
DISPLAY_NUM=1
