# API Key for the AI Agent
ANTHROPIC_API_KEY=your_api_key_here

# Use the official Anthropic API endpoint (default when not specified)
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# Model to use (Claude Haiku 4.5 for faster responses, or use claude-sonnet-4-5-20250929)
ANTHROPIC_MODEL=your_model_here

# (Optional) Display Configuration
WIDTH=1024
HEIGHT=768

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=dual                          # console, json, or dual
LOG_DIR=/data/logs
LOG_MAX_SIZE_MB=10
LOG_BACKUP_COUNT=5

# Logging Feature Flags
ENABLE_PERFORMANCE_LOGGING=true
ENABLE_DATABASE_QUERY_LOGGING=true      # Use DEBUG level in production
ENABLE_API_REQUEST_LOGGING=true
ENABLE_TOOL_EXECUTION_LOGGING=true
